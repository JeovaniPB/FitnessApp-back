generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id          String      @id @default(uuid())
  nombre      String
  email       String      @unique
  password    String

  rutinas     Rutina[]
  progresos   Progreso[]
  objetivos   ObjetivoUsuario[]
  dietas      Dieta[]
  historiales HistorialEntrenamiento[]

  createdAt   DateTime @default(now())
}

model Rutina {
  id           String      @id @default(uuid())
  nombre       String
  objetivo     String
  nivel        String
  diasSemana   Int
  estado       String      @default("activa")
  fechaInicio  DateTime?

  usuarioId    String
  usuario      Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  ejercicios   Ejercicio[]

  createdAt    DateTime @default(now())
}

model CategoriaEjercicio {
  id           String       @id @default(uuid())
  nombre       String       @unique

  ejercicios   Ejercicio[]
}

model Ejercicio {
  id             String      @id @default(uuid())
  nombre         String
  series         String      
  repeticiones   String      
  descanso       Int         @default(60)

  rutinaId       String
  rutina         Rutina @relation(fields: [rutinaId], references: [id], onDelete: Cascade)

  categoriaId    String?
  categoria      CategoriaEjercicio? @relation(fields: [categoriaId], references: [id])

  createdAt      DateTime    @default(now())
}

model Progreso {
  id              String    @id @default(uuid())
  pesoActual      Float
  calorias        Int
  porcentajeGrasa Float
  fecha           DateTime @default(now())

  usuarioId       String
  usuario         Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
}

model ObjetivoUsuario {
  id          String   @id @default(uuid())
  tipo        String
  descripcion String

  usuarioId   String
  usuario     Usuario @relation(fields: [usuarioId], references: [id])
}

model Dieta {
  id          String   @id @default(uuid())
  nombre      String
  calorias    Int
  proteina    Int
  carbohidratos Int
  grasas      Int

  usuarioId   String
  usuario     Usuario @relation(fields: [usuarioId], references: [id])
}

model HistorialEntrenamiento {
  id               String   @id @default(uuid())
  fecha            DateTime @default(now())
  duracionMinutos  Int
  caloriasQuemadas Int

  usuarioId        String
  usuario          Usuario @relation(fields: [usuarioId], references: [id])
}